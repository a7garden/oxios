# Local overrides for dependencies (development)
# Place a Cargo.toml.local at the workspace root to override workspace.dependencies.
# Example Cargo.toml.local:
#   [workspace.dependencies]
#   oxi-ai = { path = "../oxi/oxi-ai" }
#   oxi-agent = { path = "../oxi/oxi-agent" }
Cargo.toml.local

# AI agent temporary analysis files — generated during sessions,
# never committed. Use docs/ for persistent documents.
*-analysis.md
analysis-*.md
fix-*.md
*-output.md
*-result.md
*-audit.txt
calculation_result.md
page_snapshot.md

# Subagent fallback temp reports at the repo root
local:
report-*.json
