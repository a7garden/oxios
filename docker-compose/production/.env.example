# Oxios Self-Hosting Environment Variables
# Copy to .env and fill in your values.

# ── Required ────────────────────────────────────────────────────
# At least one provider API key is needed for LLM access.

# Anthropic (Claude)
OXIOS_ANTHROPIC_API_KEY=

# OpenAI (GPT, o-series)
OXIOS_OPENAI_API_KEY=

# Google (Gemini)
OXIOS_GOOGLE_API_KEY=

# DeepSeek
OXIOS_DEEPSEEK_API_KEY=

# Groq (fast inference)
OXIOS_GROQ_API_KEY=

# OpenRouter (multi-provider gateway)
OXIOS_OPENROUTER_API_KEY=

# Mistral
OXIOS_MISTRAL_API_KEY=

# ── Optional ────────────────────────────────────────────────────

# Oxios web UI port (default: 9876)
OXIOS_PORT=9876

# Host workspace directory mounted into the container (read-only)
# Agents will have read access to this path.
OXIOS_WORKSPACE=~/oxios-workspace

# Log level (trace, debug, info, warn, error)
OXIOS_LOG_LEVEL=info

# ── Optional: PostgreSQL persistence ────────────────────────────
# Uncomment to enable database-backed state storage.
# When unset, Oxios uses ~/.oxios filesystem storage.
# POSTGRES_URL=postgres://oxios:oxios@postgres:5432/oxios
# POSTGRES_PASSWORD=oxios

# ── Optional: Redis caching ─────────────────────────────────────
# REDIS_URL=redis://redis:6379
