# Oxios Environment Variables
#
# Copy this file to .env and fill in values.
# Environment variables take highest priority over config.toml.

# ── LLM Provider Keys ──
# Primary: OXIOS_<PROVIDER>_API_KEY format
OXIOS_ANTHROPIC_API_KEY=
OXIOS_OPENAI_API_KEY=

# ── Web Channel ──
# OXIOS_API_KEY=           # Bearer token for API authentication
# OXIOS_PORT=4200          # Override gateway port

# ── MCP Servers ──
# OXIOS_MCP_<NAME>_COMMAND=/path/to/server
# OXIOS_MCP_<NAME>_ARGS=arg1 arg2
# OXIOS_MCP_<NAME>_ENV=KEY1=val1,KEY2=val2

# ── Logging ──
# RUST_LOG=oxios=info,oxios_kernel=debug

# ── Docker-specific ──
# OXIOS_LOG_FORMAT=json    # json|pretty|compact — default: pretty
