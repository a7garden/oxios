# Oxios Environment Variables
#
# NOTE: Prefer config.toml [secrets] section for all sensitive values.
# Copy to ~/.oxios/config.toml and set [secrets] fields there.
# Environment variables below are fallback for CI/CD and containers only.
#
# Priority: config.toml [secrets] → ~/.oxi/auth.json → env var

# ── LLM Provider Keys (fallback for OXIOS_<PROVIDER>_API_KEY) ──
# Prefer: [secrets.providers] in config.toml
# OXIOS_ANTHROPIC_API_KEY=
# OXIOS_OPENAI_API_KEY=

# ── Web Channel ──
# Prefer: [secrets].oxios_api_key in config.toml
# OXIOS_API_KEY=

# ── MCP Servers ──
# Prefer: [mcp.servers] in config.toml
# OXIOS_MCP_<NAME>_COMMAND=/path/to/server
# OXIOS_MCP_<NAME>_ARGS=arg1 arg2
# OXIOS_MCP_<NAME>_ENV=KEY1=val1,KEY2=val2

# ── Logging ──
# RUST_LOG=oxios=info,oxios_kernel=debug

# ── Docker-specific ──
# OXIOS_LOG_FORMAT=json    # json|pretty|compact — default: pretty
